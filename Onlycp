def clean_result_for_api(result:Dict[str,Any]):

    combined=result.get("combined_summary")

    raw=result.get("individualized_summary",[])

    cleaned=[]

    for item in raw:

        cleaned.append({

            "file_name":item.get("file_name"),
            "summary":item.get("summary"),
            "document_type":item.get("document_type"),
            "processed_summary":item.get("processed_summary")

        })

    return{

        "combined_summary":combined,
        "individualized_summary":cleaned

    }



async def summarize_blob_pdfs_layout(blob_urls:List[str]):

    try:

        summary_require_env()

    except Exception:

        return{

            "combined_summary":None,
            "individualized_summary":[]

        }


    summaries=[]


    for blob_url in blob_urls:

        try:

            container,filename,reference_number=\
                await extract_filename_referencenumber_container_name(blob_url)

        except Exception as e:

            summaries.append({

                "blob_url":blob_url,
                "file_name":None,
                "reference_number":None,
                "summary":None,
                "text":None,
                "error":str(e)

            })

            continue


        try:

            text=await read_text_file_from_container(filename)

        except Exception as e:

            summaries.append({

                "blob_url":blob_url,
                "file_name":filename,
                "reference_number":reference_number,
                "summary":None,
                "text":None,
                "error":str(e)

            })

            continue


        try:

            summary_text=summarize_first_page(

                {"first_page_text":text},
                file_name=filename

            )

        except Exception as e:

            summaries.append({

                "blob_url":blob_url,
                "file_name":filename,
                "reference_number":reference_number,
                "summary":None,
                "text":text,
                "error":str(e)

            })

            continue


        summaries.append({

            "blob_url":blob_url,
            "file_name":filename,
            "reference_number":reference_number,
            "summary":summary_text,
            "text":text,
            "error":None

        })


    result={

        "status":True,
        "summaries":summaries

    }


    try:

        await download_blob_to_input_folder_by_reference(

            summaries,
            output_folder=EMAIL_BODY,
            container_name="attachment-downloader",
            blob_name_template="body_{ref}.txt"

        )

    except Exception as e:

        print("Email download failed:",e)



    try:

        combined_summary=summarize_attachments(summaries)

        result["combined_summary"]=combined_summary

    except Exception:

        result["combined_summary"]=None



    try:

        valid=[

            s for s in summaries

            if s.get("file_name") and s.get("summary")

        ]

        individualized=individual_summary(valid)

        result["individualized_summary"]=individualized

    except Exception:

        result["individualized_summary"]=[]



    cleaned=clean_result_for_api(result)

    beautified=beautify_api_response(cleaned)


    DATA_URL=os.getenv("Data_URL")

    if DATA_URL:

        try:

            connect_to_blob(DATA_URL,beautified)

        except Exception as e:

            print("Excel update failed:",e)


    return beautified


