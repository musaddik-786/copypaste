from dotenv import load_dotenv
import os
from typing import List, Dict, Any
from openai import AzureOpenAI

load_dotenv()

AZURE_OPENAI_ENDPOINT = os.getenv("AZURE_OPENAI_ENDPOINT")
AZURE_OPENAI_API_VERSION = os.getenv("AZURE_OPENAI_API_VERSION")
AZURE_OPENAI_API_KEY = os.getenv("AZURE_OPENAI_API_KEY")
AZURE_OPENAI_CHAT_DEPLOYMENT = os.getenv("AZURE_OPENAI_CHAT_DEPLOYMENT")

if not (
    AZURE_OPENAI_ENDPOINT
    and AZURE_OPENAI_API_VERSION
    and AZURE_OPENAI_API_KEY
    and AZURE_OPENAI_CHAT_DEPLOYMENT
):
    raise RuntimeError("Azure OpenAI env vars missing.")

client = AzureOpenAI(
    api_key=AZURE_OPENAI_API_KEY,
    api_version=AZURE_OPENAI_API_VERSION,
    azure_endpoint=AZURE_OPENAI_ENDPOINT,
)


def _call_chat_llm(prompt: str, max_tokens: int = 700, temperature: float = 0.2):

    response = client.chat.completions.create(
        model=AZURE_OPENAI_CHAT_DEPLOYMENT,
        messages=[{"role": "user", "content": prompt}],
        max_tokens=max_tokens,
        temperature=temperature,
    )

    return response.choices[0].message.content.strip()


def generate_professional_summary(text: str):

    text = text[:5000]

    prompt = f"""
You are a Senior Commercial Insurance Underwriter.

You are given raw document text from an insurance submission.

Your task is to generate a PROFESSIONAL underwriting summary.

STRICT RULES:

• Use ONLY information present in the document
• Do NOT hallucinate
• Do NOT guess values
• If information missing write "Not Present"
• Keep professional underwriting tone
• Use headings
• Use bullet points
• Keep structure clean
• Focus only on underwriting relevant information
• Do NOT mention document type
• Do NOT mention source text
• Do NOT explain what you are doing

OUTPUT FORMAT:

DOCUMENT SUMMARY

INSURED DETAILS
• Named Insured:
• Address:
• Business Type:
• Operations:

PROPERTY DETAILS
• Number of Locations:
• Construction:
• Year Built:
• Square Footage:
• Occupancy:
• Protection Systems:

COVERAGE DETAILS
• Line of Business:
• Effective Date:
• Expiry Date:
• Limits:
• Valuation:

FINANCIAL DETAILS
• Total Insured Value:
• Revenue:
• Payroll:
• Business Income:

LOSS DETAILS
• Loss History:
• Major Losses:
• Trends:

RISK CONSIDERATIONS
• Key Exposures:
• CAT Exposure:
• Dependencies:

UNDERWRITER NOTES
• Key observations
• Risk quality indicators
• Important underwriting considerations

DOCUMENT TEXT:
\"\"\"
{text}
\"\"\"
"""

    return _call_chat_llm(prompt)


def individual_summary(attachments: List[Dict[str, Any]]):

    for attachment in attachments:

        file_name = attachment.get("file_name","")
        text = attachment.get("text","")

        print(f"Processing summary for {file_name}")

        processed_summary = generate_professional_summary(text)

        attachment["processed_summary"] = processed_summary

        print(f"Processed Summary completed for {file_name}")

    return attachments
