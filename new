import asyncio
from typing import TypedDict, Annotated

from langgraph.graph import StateGraph, START, END
from langgraph.graph.message import add_messages

# IMPORT SUBGRAPHS
from email_intent_agent.langgraph_client import build_email_intent_graph
from eligibility_agent.langgraph_client import build_eligibility_graph
from risk_assesment_agent.langgraph_client import build_risk_graph


class State(TypedDict):
    messages: Annotated[list, add_messages]


async def build_megagraph():

    # build all subgraphs
    email_graph = await build_email_intent_graph()
    eligibility_graph = await build_eligibility_graph()
    risk_graph = await build_risk_graph()

    builder = StateGraph(State)

    # Add subgraphs as nodes
    builder.add_node("EmailIntentAgent", email_graph)
    builder.add_node("EligibilityAgent", eligibility_graph)
    builder.add_node("RiskAssessmentAgent", risk_graph)

    # Graph Flow
    builder.add_edge(START, "EmailIntentAgent")

    builder.add_edge("EmailIntentAgent", "EligibilityAgent")

    builder.add_edge("EligibilityAgent", "RiskAssessmentAgent")

    builder.add_edge("RiskAssessmentAgent", END)

    return builder.compile()


async def main():

    graph = await build_megagraph()

    async for step in graph.astream(
        {"messages": ["Start underwriting workflow"]},
        config={"recursion_limit": 200},
    ):
        print(step)


if __name__ == "__main__":
    asyncio.run(main())




import os
import asyncio
from typing import TypedDict, Annotated

from langgraph.graph import StateGraph, START, END
from langgraph.graph.message import add_messages
from langgraph.prebuilt import ToolNode
from langchain_core.messages import AIMessage, SystemMessage

from langchain_mcp_adapters.client import MultiServerMCPClient
from langchain_openai.chat_models import AzureChatOpenAI


class State(TypedDict):
    messages: Annotated[list, add_messages]


def router(state: State):
    last = state["messages"][-1]

    if isinstance(last, AIMessage) and last.tool_calls:
        return "tools"

    if isinstance(last, AIMessage) and last.content:
        content = last.content.strip()
        if content == "Continue":
            return "agent"
        if content == "End":
            return "end"

    return "end"


def load_prompt():
   base_path = os.path.dirname(__file__)
   prompt_path = os.path.join(base_path, "prompt_eligibility.txt")
   with open(prompt_path, "r", encoding="utf-8") as f:
       return f.read()


async def build_eligibility_graph():

    mcp_client = MultiServerMCPClient({
        "dummy_mcp": {
            "url": "http://localhost:3420/mcp",
            "transport": "streamable_http",
        }
    })

    # all_tools = await mcp_client.get_tools()
    all_tools = await mcp_client.get_tools()



    model = AzureChatOpenAI(
    api_key="A",
    api_version="2",
    azure_deployment="g",
    azure_endpoint="/"
   )

    llm = model.bind_tools(all_tools)
    # llm = model.bind_tools(filtered_tools)
    prompt = load_prompt()

    async def agent_node(state: State):
        system = SystemMessage(content=prompt)
        response = await llm.ainvoke([system] + state["messages"])
        return {"messages": [response]}

    graph = StateGraph(State)

    graph.add_node("agent", agent_node)
    graph.add_node("tools", ToolNode(all_tools))
    # graph.add_node("tools", ToolNode(filtered_tools))


    graph.add_edge(START, "agent")

    graph.add_conditional_edges(
        "agent",
        router,
        {
            "tools": "tools",
            "agent": "agent",
            "end": END,
        },
    )

    graph.add_edge("tools", "agent")

    return graph.compile()


async def main():
    graph = await build_eligibility_graph()

    async for step in graph.astream(
        {"messages": ["Start eligibility workflow"]},
        config={"recursion_limit": 40},
    ):
        print(step)


if __name__ == "__main__":
    asyncio.run(main())



