# Below one is the new retriever_mcp router part with database-driven dynamic prompts approach
@router.post("/retriever_mcp", operation_id="retriever_mcp")
async def retriever_mcp(
    p_body: RetrieverMCP,
):
    """Extract values for attributes from vectorized PDF using semantic search with database-driven dynamic prompts.
    
    This MCP works in conjunction with pdf_vectorizer_mcp:
    1. pdf_vectorizer_mcp: Takes blob_url, chunks and embeds PDF, returns vector_db_path
    2. retriever_mcp: Takes vector_db_path + document_type, fetches prompt and extraction rules from PostgreSQL,
                      extracts values using semantic search, groups results by category
    
    Args:
        p_body (RetrieverMCP): Request body containing:
            - VectorDbPath: Path to vector database from pdf_vectorizer_mcp output
            - DocumentType: Layout type of the Document which will be provided by the layout_detection_mcp for fetching prompt and extraction rules from ref_prompt_library table
    
    Returns:
        JSONResponse: Contains extraction results, output blob URL, and metadata
    """
    try:
        result = await process_retrieval(
            vector_db_path=p_body.VectorDbPath,
            document_type=p_body.DocumentType
        )
        
        return JSONResponse(content={
            "jsonrpc": "2.0",
            "id": 1,
            "result": result
        })
        
    except Exception as e:
        return JSONResponse(
            content={
                "jsonrpc": "2.0",
                "id": 1,
                "error": {
                    "code": 500,
                    "message": f"Error retrieving values: {str(e)}"
                }
            },
            status_code=500
        )







