    # sender_email: str = None
    

class DraftResponse(BaseModel):
    draft_id: str
    message: str

@router.post(
    "/email_draft_mcp", response_model=DraftResponse,
     summary="",
    openapi_extra={"description": ""},
    operation_id="email_draft_mcp"
    )
async def create_draft_endpoint(request: DraftRequest):
    
    """
    Create an email draft in the sender's Gmail account with a specified email body and attachment.

    This endpoint accepts an email body and an attachment URL to create a draft email. The attachment URL is expected to be 
    provided by a Quote generator MCP. The URL can point to various sources including standard HTTP/HTTPS links 
    or Azure Blob Storage URLs (public or private). The system handles downloading the attachment from these URLs automatically.

    The sender and recipient email addresses are fetched exclusively from environment variables:
    `GMAIL_USER_EMAIL` for the sender and `GMAIL_RECIPIENT_EMAIL` for the recipient. It returns a unique draft ID and a success message.

    Parameters:
    - request (DraftRequest): The request body containing:
        - email_body_text (str, optional): The text content of the email body.
        - attachment_url (str, optional): URL of the attachment to include in the draft, 
        which can be a standard web URL or an Azure Blob Storage URL.

    Returns:
    - DraftResponse: A response model containing:
        - draft_id (str): The unique identifier of the created draft.
        - message (str): Confirmation message indicating success.

    Raises:
    - HTTPException (500): If the draft creation fails due to an internal error or if required
    environment variables for sender or recipient emails are missing.
    """

    sender_email = os.getenv("GMAIL_USER_EMAIL")
    recipient_email = os.getenv("GMAIL_RECIPIENT_EMAIL")

    if not sender_email or not recipient_email:
        raise HTTPException(
            status_code=500,
            detail="Sender or recipient email environment variables are not set."
        )

    try:
        draft_id = create_email_draft(
            email_body_text=request.email_body_text,
            attachment_url=request.attachment_url,
            recipient_email=recipient_email,  # Fetched from environment variable 
            sender_email=sender_email  # Fetched from environment variable
        )
        return DraftResponse(draft_id=draft_id, message="Draft created successfully")
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Failed to create draft: {e}")
        

