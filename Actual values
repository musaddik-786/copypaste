load_dotenv()
endpoint = os.getenv("LD_AZURE_FORMRECOG_ENDPOINT")
key = os.getenv("LD_AZURE_FORMRECOG_KEY")
client = DocumentAnalysisClient(
   endpoint=endpoint,
   credential=AzureKeyCredential(key)
