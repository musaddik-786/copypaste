import mammoth
from weasyprint import HTML
def convert_docx_to_pdf(input_docx, output_pdf):
   with open(input_docx, "rb") as docx_file:
       html = mammoth.convert_to_html(docx_file).value
   HTML(string=html).write_pdf(output_pdf)
