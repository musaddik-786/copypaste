import os
import json
from typing import Optional, Dict, Any
import pandas as pd
from azure.storage.blob.aio import BlobServiceClient
from azure.core.exceptions import ResourceNotFoundError
from dotenv import load_dotenv
from io import BytesIO
import openpyxl
from datetime import datetime
from zoneinfo import ZoneInfo
import traceback
import sys
from service import _require_env, _parse_blob_url
load_dotenv()
AZURE_STORAGE_CONNECTION_STRING = os.environ.get("AZURE_STORAGE_CONNECTION_STRING","")
LOCAL_CSV_PATH = os.path.join("input","sanctions.csv")
FETCHED_EMAILS_EXCEL_BLOB_URL="https://agenticai1.blob.core.windows.net/output-results/Fetched_emails_data_new.xlsx"
TARGET_BLOB_EXCEL_URL="https://agenticai1.blob.core.windows.net/output-results/eligibility.xlsx"
LOCAL_STUBBED_EXCEL_PATH=os.path.join("input","stubbed.xlsx")
async def compare_name_with_sanctions(json_file_url:str,detected_lob:str)->Dict[str,Any]:
   try:
       _require_env()
   except Exception as e:
       return {"status":False,"error":str(e)}
   try:
       container_name,blob_name=_parse_blob_url(json_file_url)
   except Exception as e:
       return {"status":False,"error":str(e)}
   try:
       async with BlobServiceClient.from_connection_string(AZURE_STORAGE_CONNECTION_STRING) as blob_service:
           container_client=blob_service.get_container_client(container_name)
           blob_client=container_client.get_blob_client(blob_name)
           await blob_client.get_blob_properties()
           stream=await blob_client.download_blob()
           raw_bytes=await stream.readall()
   except Exception as e:
       return {"status":False,"error":str(e)}
   try:
       data=json.loads(raw_bytes.decode("utf-8"))
   except Exception as e:
       return {"status":False,"error":str(e)}
   target_labels={"nameandmailingaddress","clientname"}
   extracted_name:Optional[str]=None
   def search_nested(data_obj):
       if isinstance(data_obj,dict):
           for key,value in data_obj.items():
               if isinstance(value,dict):
                   res=search_nested(value)
                   if res:
                       return res
               elif isinstance(value,list):
                   for elem in value:
                       if isinstance(elem,dict):
                           res=search_nested(elem)
                           if res:
                               return res
               elif isinstance(key,str):
                   normalized_key=key.lower().replace(" ","")
                   if normalized_key in target_labels:
                       return str(value).split(",")[0].strip()
       return None
   extracted_name=search_nested(data)
   if not extracted_name:
       excel_status=await _append_and_copy_columns_to_target_blob(None,detected_lob)
       return {"status":False,"error":"Name not found","excel_update":excel_status}
   if not os.path.exists(LOCAL_CSV_PATH):
       excel_status=await _append_and_copy_columns_to_target_blob(None,detected_lob)
       return {"status":False,"error":"CSV missing"}
   csv_df=pd.read_csv(LOCAL_CSV_PATH)
   def norm(s):
       return s.strip().lower() if isinstance(s,str) else ""
   entity_set={norm(x) for x in csv_df["entity_name"].dropna() if isinstance(x,str)}
   is_sanctioned=norm(extracted_name) in entity_set
   results=[{
       "Extracted Name":extracted_name,
       "is_Sanctioned":is_sanctioned
   }]
   excel_status=await _append_and_copy_columns_to_target_blob(
       is_sanctioned,
       detected_lob
   )
   return {
       "status":True,
       "results":results,
       "excel_update":excel_status
   }

async def _append_and_copy_columns_to_target_blob(extracted_flag:Optional[bool],detected_lob:str)->Dict[str,Any]:
   async with BlobServiceClient.from_connection_string(AZURE_STORAGE_CONNECTION_STRING) as blob_service:
       src_container,src_blob=_parse_blob_url(FETCHED_EMAILS_EXCEL_BLOB_URL)
       src_client=blob_service.get_blob_client(src_container,src_blob)
       src_stream=await src_client.download_blob()
       src_bytes=await src_stream.readall()
       src_wb=openpyxl.load_workbook(BytesIO(src_bytes),read_only=True)
       src_ws=src_wb.active
       last_value=None
       for r in range(src_ws.max_row,0,-1):
           v=src_ws.cell(r,1).value
           if v:
               last_value=str(v)
               break
       src_wb.close()
       tgt_container,tgt_blob=_parse_blob_url(TARGET_BLOB_EXCEL_URL)
       tgt_client=blob_service.get_blob_client(tgt_container,tgt_blob)
       try:
           tgt_bytes=await (await tgt_client.download_blob()).readall()
           wb=openpyxl.load_workbook(BytesIO(tgt_bytes))
       except:
           wb=openpyxl.Workbook()
       ws=wb.active
       last_row=0
       for r in range(ws.max_row,0,-1):
           if ws.cell(r,1).value:
               last_row=r
               break
       write_row=last_row+1 if last_row else 2
       ws.cell(write_row,1,last_value)
       now=datetime.now(ZoneInfo("Asia/Kolkata"))
       ws.cell(write_row,2,now.strftime("%m/%d/%Y %I:%M:%S %p"))
       lob=detected_lob.strip().upper()
       if lob=="RESIDENTIAL PROPERTY":
           source_row=5 if extracted_flag else 4
       else:
           source_row=3 if extracted_flag else 2
       if extracted_flag is not None:
           wb_local=openpyxl.load_workbook(LOCAL_STUBBED_EXCEL_PATH,data_only=True)
           ws_local=wb_local.active
           for col in range(3,11):
               ws.cell(write_row,col,ws_local.cell(source_row,col).value)
           wb_local.close()
       bio=BytesIO()
       wb.save(bio)
       bio.seek(0)
       await tgt_client.upload_blob(bio.getvalue(),overwrite=True)
       wb.close()
       return {
           "status":True,
           "row_used":source_row,
           "lob":detected_lob
       }


