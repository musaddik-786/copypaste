🧠 5️⃣ MEGA GRAPH

📁 mega_graph.py

from email_intent_agent.graph import build_email_graph
from eligibility_agent.graph import build_eligibility_graph
from risk_agent.graph import build_risk_graph


def build_mega_graph(model):

    email_graph = build_email_graph(model)
    eligibility_graph = build_eligibility_graph(model)
    risk_graph = build_risk_graph(model)

    async def mega(state):

        if not state.get("email_completed"):
            return await email_graph.ainvoke(state)

        if not state.get("eligibility_completed"):
            return await eligibility_graph.ainvoke(state)

        if not state.get("risk_completed"):
            return await risk_graph.ainvoke(state)

        return state

    return mega


