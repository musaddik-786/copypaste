from langchain_community.tools.fastapi_mcp import FastApiMCPToolkit

async def load_mcp_tools():
    toolkit = FastApiMCPToolkit.from_http(
        url="http://localhost:9000/mcp"
    )
    return toolkit.get_tools()


def filter_tools(all_tools, allowed_names):
    return [t for t in all_tools if t.name in allowed_names]


