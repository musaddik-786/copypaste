from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from fastapi_mcp import FastApiMCP
from router import router

app = FastAPI(title="Dummy MCP Server")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

app.include_router(router)

# Expose ALL operations
FastApiMCP(
    app,
    include_operations=[
        # Email
        "email_reader_mcp",
        "write_email_to_excel",
        "email_attachment_mcp",
        "layout_detection_mcp",
        "document_extract_mcp",
        "query_pdf_vectorizer_mcp",
        "attachment_summary_mcp",

        # Eligibility
        "risk_type_checker_MCP",
        "renewal_checker_mcp",
        "Licensing_and_Sanction_Checker_MCP",
        "Json_Reader_Read",

        # Risk
        "risk_data_capture_mcp",
        "risk_score_calculator_mcp",
        "accept_reject_risk_functionality_mcp",
    ]
).mount_http()


