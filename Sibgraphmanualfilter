📁 mega_graph.py

async def build_mega_graph(model):

    from email_intent_agent.graph import build_email_graph
    from eligibility_agent.graph import build_eligibility_graph
    from risk_agent.graph import build_risk_graph

    email_graph = await build_email_graph(model)
    eligibility_graph = await build_eligibility_graph(model)
    risk_graph = await build_risk_graph(model)

    async def run_all():

        state = {"messages": []}

        state = await email_graph.ainvoke(state)
        state = await eligibility_graph.ainvoke(state)
        state = await risk_graph.ainvoke(state)

        return state

    return run_all


