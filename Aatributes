def get_final_prompt(text: str) -> str:
    """
    Loads Phoenix prompt template and injects runtime text.

    Steps:
    1 Load prompt from Phoenix
    2 Validate template variable
    3 Inject runtime text
    4 Return final prompt

    Args:
        text (str): Input text

    Returns:
        str : Final formatted prompt
    """

    # Create Phoenix client
    client = Client(
        base_url=PHOENIX_ENDPOINT,
        api_key=PHOENIX_API_KEY
    )

    # Fetch prompt
    prompt = client.prompts.get(
        prompt_version_id="UHJvbXB0VmVyc2lvbjoxMw=="
    )

    # Extract messages
    prompt_messages = prompt._template["messages"]

    system_prompt = next(

        (
            item["content"][0]["text"]
            for item in prompt_messages
            if item.get("role") == "system"
        ),

        None
    )

    if not system_prompt:
        raise ValueError(
            "Phoenix prompt missing or invalid"
        )

    # Format prompt
    try:

        final_prompt = system_prompt.format(
            text=text
        )

    except KeyError as e:

        raise ValueError(
            f"Missing variable in prompt: {e}"
        )

    return final_prompt


