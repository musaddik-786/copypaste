        }

       
    
    def get_connection(self):
        """Establish database connection"""
        try:
            conn = psycopg2.connect(**self.connection_params)
            return conn
        except Exception as e:
            logger.error(f"❌ Database connection failed: {str(e)}")
            return None
    
    def get_prompt_and_extraction_rules(self, document_type: str) -> Optional[Dict]:
        """
        Fetch prompt and extraction rules from database by document type using SQL query.
        
        Query: SELECT prompt, extraction_rules FROM ref_prompt_library WHERE document_type = ?
        
        Args:
            document_type: Document type name (e.g., 'quote', 'acord', 'inspection_report')
        
        Returns:
            Dictionary with 'prompt' and 'extraction_rules' keys, or None if not found
        """
        conn = self.get_connection()
        if not conn:
            logger.warning(f"⚠️  No database connection - cannot fetch data for {document_type}")
            return None
        
        try:
            cur = conn.cursor(cursor_factory=RealDictCursor)
            # Single SQL query to fetch both prompt and extraction rules
            query = """
            SELECT prompt, extraction_rules 
            FROM ref_prompt_library 
            WHERE LOWER(document_type) = LOWER(%s)
            LIMIT 1
            """
            cur.execute(query, (document_type,))
            result = cur.fetchone()
            
            if result and result['prompt']:
                logger.info(f"✅ Fetched prompt and extraction rules for document type: {document_type}")
                # Parse extraction_rules JSON string from database into Python dict
                extraction_rules = {}
                if result['extraction_rules']:
                    try:
                        if isinstance(result['extraction_rules'], str):
                            extraction_rules = json.loads(result['extraction_rules'])
                        else:
                            extraction_rules = result['extraction_rules']
                    except json.JSONDecodeError as e:
                        logger.warning(f"⚠️  Failed to parse extraction_rules JSON: {str(e)}")
                        extraction_rules = {}
                
                return {
                    'prompt': result['prompt'],
                    'extraction_rules': extraction_rules
                }
            else:
                logger.warning(f"⚠️  No data found for document type: {document_type}")
                return None
        except Exception as e:
            logger.error(f"❌ Error fetching prompt and rules: {str(e)}")
            return None
        finally:
            if conn:
                conn.close()


