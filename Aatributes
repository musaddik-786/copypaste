class PostgreSQLPromptManager:
    """Manages dynamic prompt fetching from PostgreSQL"""
    
    def __init__(self):
        self.connection_params = {
            "host": os.getenv("PGHOST", "jarvis-uw.postgres.database.azure.com"),
            "port": int(os.getenv("PGPORT", "5432")),
