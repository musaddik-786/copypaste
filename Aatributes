def _determine_decision(score: float, thr: RiskThresholds) -> Tuple[str, str, bool]:
    """
    Multi-band Accept/Review/Decline logic based on configured thresholds.

    Returns:
      - decision: str
      - message: str (explains which band was matched)
      - needs_review: bool (whether human-in-the-loop is required)
    """
    def in_band(value: float, band: Dict) -> bool:
        lower_ok = value >= band["lower"] if band["include_lower"] else value > band["lower"]
        upper_ok = value <= band["upper"] if band["include_upper"] else value < band["upper"]
        return lower_ok and upper_ok

    for band in thr.bands:
        if in_band(score, band):
            decision = band["decision"]
            lower_bracket = "[" if band["include_lower"] else "("
            upper_bracket = "]" if band["include_upper"] else ")"
            msg = (
                f"Risk score {score} falls in {lower_bracket}{band['lower']}, {band['upper']}{upper_bracket} "
                f"→ Decision: {decision}"
            )
            return (decision, msg, band["needs_review"])

    # If no band captures the score, flag for review.
    return (
        "Needs Review",
        f"Risk score {score} is not covered by configured thresholds; manual review required",
        True,
    )

