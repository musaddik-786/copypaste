class RiskThresholds:
    """
    Multi-band risk thresholds.

    Default bands (continuous coverage, no gaps):
      - Auto-Accept:        score <= 200
      - Accept:             200 < score <= 350
      - Accept w/ Cond.:    350 < score <= 500
      - Senior UW Review:   500 < score <= 650
      - Refer to Specialty: 650 < score <= 800
      - DECLINE:            800 < score <= 1000
    """
    def __init__(self, bands: List[Dict] = None):
        # Each band is defined with bounds and inclusivity, plus decision and whether human review is needed.
        # Inclusivity is set to ensure continuous coverage without gaps for float scores.
        if bands is None:
            bands = [
                {
                    "lower": float("-inf"),
                    "upper": 200.0,
                    "include_lower": True,
                    "include_upper": True,
                    "decision": "Auto-Accept",
                    "needs_review": False,
                },
                {
                    "lower": 200.0,
                    "upper": 350.0,
                    "include_lower": False,  # (200, 350]
                    "include_upper": True,
                    "decision": "Accept",
                    "needs_review": False,
                },
                {
                    "lower": 350.0,
                    "upper": 500.0,
                    "include_lower": False,  # (350, 500]
                    "include_upper": True,
                    "decision": "Accept w/ Conditions",
                    "needs_review": True,  # Conditions typically require human oversight
                },
                {
                    "lower": 500.0,
                    "upper": 650.0,
                    "include_lower": False,  # (500, 650]
                    "include_upper": True,
                    "decision": "Senior UW Review",
                    "needs_review": True,
                },
                {
                    "lower": 650.0,
                    "upper": 800.0,
                    "include_lower": False,  # (650, 800]
                    "include_upper": True,
                    "decision": "Refer to Specialty",
                    "needs_review": True,
                },
                {
                    "lower": 800.0,
                    "upper": 1000.0,
                    "include_lower": False,  # (800, 1000]
                    "include_upper": True,
                    "decision": "DECLINE",
                    "needs_review": False,
                },
            ]
        self.bands = bands

    def validate_thresholds(self) -> bool:
        """
        Validates that bands are:
          - Properly ordered,
          - Non-overlapping considering inclusivity,
          - Have lower <= upper for each band.
        """
        if not self.bands:
            return False

        # Sort by lower bound for validation purposes
        bands = sorted(self.bands, key=lambda b: (b["lower"], not b["include_lower"]))

        def overlaps(b1: Dict, b2: Dict) -> bool:
            # Determine if two bands overlap considering inclusivity
            # b1 comes before b2 (sorted)
            if b1["upper"] < b2["lower"]:
                return False
            if b1["upper"] > b2["lower"]:
                return True
            # b1["upper"] == b2["lower"] -> overlap only if both include the shared boundary
            return b1["include_upper"] and b2["include_lower"]

        for b in bands:
            if b["lower"] > b["upper"]:
                return False

        for i in range(1, len(bands)):
            if overlaps(bands[i - 1], bands[i]):
                return False

        return True


# Utils
def _require_env() -> None:
    if not AZURE_STORAGE_CONNECTION_STRING:
        raise RuntimeError("Missing AZURE_STORAGE_CONNECTION_STRING in environment")

def _parse_container_from_url(url: str) -> Tuple[str, str]:
    """
    Parse an Azure Blob URL and return (account_host, container_name).
    Accepts either a container URL or any blob URL within that container.
    """
    parsed = urlparse(url)
    if not parsed.scheme.startswith("http"):
        raise ValueError("input_blob_url must be a valid http(s) Azure Blob URL")
    account_host = parsed.netloc
    path = parsed.path.lstrip("/")
    if not path:
        raise ValueError("input_blob_url must include at least the container name")
    container = path.split("/", 1)[0]
    return account_host, unquote(container)

def _parse_container_and_blob_from_url(url: str) -> Tuple[str, str, Optional[str]]:
    """
    Parse an Azure Blob URL and return (account_host, container_name, blob_path_or_none).
    If the URL points to a specific blob, blob_path_or_none is the path after the container.
    If it points to the container root, blob_path_or_none is None.
    """
    parsed = urlparse(url)
    if not parsed.scheme.startswith("http"):
        raise ValueError("input_blob_url must be a valid http(s) Azure Blob URL")
    account_host = parsed.netloc
    path = parsed.path.lstrip("/")
    if not path:
        raise ValueError("input_blob_url must include at least the container name")
    parts = path.split("/", 1)
    container = unquote(parts[0])
    blob_path = unquote(parts[1]) if len(parts) > 1 and parts[1] else None
    return account_host, container, blob_path

def _expected_account_host_from_conn() -> Optional[str]:
    """
    Derives the expected blob account host from AZURE_STORAGE_CONNECTION_STRING.
    Priority order:
      - BlobEndpoint=https://<host>/...
      - AccountName + EndpointSuffix -> <AccountName>.blob.<EndpointSuffix>
    Returns None if it cannot be derived.
    """
    cs = AZURE_STORAGE_CONNECTION_STRING
    if not cs:
        return None
    parts: Dict[str, str] = {}
    for segment in cs.split(";"):
        if "=" in segment:
            k, v = segment.split("=", 1)
            parts[k.strip()] = v.strip()

    blob_endpoint = parts.get("BlobEndpoint")
    if blob_endpoint:
        try:
            return urlparse(blob_endpoint).netloc
        except Exception:
            return None

    account_name = parts.get("AccountName")
    endpoint_suffix = parts.get("EndpointSuffix")
    if account_name and endpoint_suffix:
        return f"{account_name}.blob.{endpoint_suffix}"

    return None

async def _get_latest_blob_name(container_client) -> str:
    """
    Returns the name of the most recently modified blob in the container.
    """
    latest_blob = None
    async for blob in container_client.list_blobs():
        if latest_blob is None or blob.last_modified > latest_blob.last_modified:
            latest_blob = blob
    if latest_blob is None:
        raise FileNotFoundError("No blobs found in the input container")
    return latest_blob.name

async def _download_latest_json_from_container(url: str) -> Tuple[str, Any, str]:
    """
    Returns (account_host, parsed JSON, blob_name) for either:
      - the most recent blob in the container (if URL points to container root), or
      - the specific blob provided in the URL (if a blob path is present).
    In case of any invalid URL or non-existent container/blob, raises ValueError('invalid url').
    """
    _require_env()

    # Parse URL; normalize any parse error to 'invalid url'
    try:
        account_host, container, blob_path = _parse_container_and_blob_from_url(url)
    except ValueError:
        raise ValueError("invalid url")

    # Validate host against connection string-derived expectation
    expected_host = _expected_account_host_from_conn()
    if expected_host and account_host != expected_host:
        raise ValueError("invalid url")

    # Enforce that the container in the URL is the expected input container
    if container != INPUT_CONTAINER:
        raise ValueError("invalid url")

    async with BlobServiceClient.from_connection_string(AZURE_STORAGE_CONNECTION_STRING) as svc:
        container_client = svc.get_container_client(container)
        try:
            # Ensure container exists
            await container_client.get_container_properties()
        except ResourceNotFoundError:
            # Treat missing container as invalid url per requirement
            raise ValueError("invalid url")

        # If a specific blob path is provided, it must exist; otherwise 'invalid url'
        if blob_path:
            blob_client = container_client.get_blob_client(blob_path)
            try:
                stream = await blob_client.download_blob()
                raw = await stream.readall()
            except ResourceNotFoundError:
                # Blob in path does not exist -> invalid url
                raise ValueError("invalid url")
            return account_host, json.loads(raw.decode("utf-8")), blob_path

        # No specific blob path: use the latest in the container
        latest_name = await _get_latest_blob_name(container_client)
        blob_client = container_client.get_blob_client(latest_name)
        stream = await blob_client.download_blob()
        raw = await stream.readall()
        return account_host, json.loads(raw.decode("utf-8")), latest_name

async def _upload_json_to_timestamped_output(account_host: str, data: Any) -> str:
    """
    Uploads to the output container using a UTC timestamped file name: accept-reject-riskfunctionality-output_YYYYMMDD_HHMMSS.json
    Returns the full output blob URL.
    """
    _require_env()
    async with BlobServiceClient.from_connection_string(AZURE_STORAGE_CONNECTION_STRING) as svc:
        container_client = svc.get_container_client(OUTPUT_CONTAINER)
        # Ensure container exists
        try:
            await container_client.create_container()
        except ResourceExistsError:
            pass

        ts = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")
        blob_name = f"accept-reject-riskfunctionality-output_{ts}.json"
        blob_client = container_client.get_blob_client(blob_name)
        payload = json.dumps(data, indent=2, ensure_ascii=False).encode("utf-8")
        await blob_client.upload_blob(payload, overwrite=True)
        return f"https://{account_host}/{OUTPUT_CONTAINER}/{blob_name}"

def _ensure_local_output_dir() -> str:
    out_dir = os.path.join(os.getcwd(), "output")
    os.makedirs(out_dir, exist_ok=True)
    return out_dir

def _save_local_results(results: List[Dict[str, Any]]) -> str:
    out_dir = _ensure_local_output_dir()
    out_file = os.path.join(out_dir, "results.json")
    with open(out_file, "w", encoding="utf-8") as f:
        json.dump(results, f, indent=2, ensure_ascii=False)
    return out_file

def _try_parse_float(value: Any) -> Optional[float]:
    try:
        if isinstance(value, (int, float)):
            return float(value)
        if isinstance(value, str):
            s = value.strip()
            if s == "":
                return None
            return float(s)
        return None
    except Exception:
        return None

def _extract_risk_items(obj: Any) -> List[Tuple[float, Optional[str], dict]]:
    """
    Recursively find all 'risk score' values in obj and return a list of tuples:
      (risk score, submission_id_if_available, the_dict_node_that_had_risk_score)
    - Only the key 'risk score' (case-sensitive) is considered.
    - submission_id is captured from the same dict level if present (case-sensitive).
    """
    results: List[Tuple[float, Optional[str], dict]] = []

    def walk(node: Any):
        if isinstance(node, dict):
            # If this dict has 'risk score', attempt to parse it and capture the dict
            if "risk score" in node:
                score = _try_parse_float(node["risk score"])
                if score is not None:
                    sub_id = None
                    if "submission_id" in node:
                        sub_id_val = node["submission_id"]
                        sub_id = str(sub_id_val) if isinstance(sub_id_val, (str, int, float)) else None
                    # Append the node (copy to avoid accidental mutation)
                    results.append((score, sub_id, dict(node)))
            # Continue recursion
            for v in node.values():
                walk(v)
        elif isinstance(node, list):
            for item in node:
                walk(item)
        # Other types ignored

    walk(obj)
    return results

