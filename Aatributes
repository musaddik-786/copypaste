import os
from phoenix.client import Client
from phoenix.otel import register
from functools import lru_cache


PHOENIX_API_KEY = os.getenv("PHOENIX_API_KEY")
PHOENIX_ENDPOINT = os.getenv("PHOENIX_ENDPOINT")


os.environ["PHOENIX_COLLECTOR_ENDPOINT"] = PHOENIX_ENDPOINT
os.environ["OTEL_EXPORTER_OTLP_ENDPOINT"] = PHOENIX_ENDPOINT
os.environ["PHOENIX_API_KEY"] = PHOENIX_API_KEY


tracer_provider = register(
    project_name="jarvis_deployed",
    auto_instrument=True
)


@lru_cache
def get_final_prompt(text: str) -> str:
    """
    Loads Phoenix prompt template and injects runtime text.

    Steps:
    1 Load prompt from Phoenix
    2 Validate template variable
    3 Inject runtime text
    4 Return final prompt

    Args:
        text (str): Input text

    Returns:
        str : Final formatted prompt
    """

    # Create Phoenix client
    client = Client(
        base_url=PHOENIX_ENDPOINT,
        api_key=PHOENIX_API_KEY
    )

    # Fetch prompt
    prompt = client.prompts.get(
        prompt_version_id="UHJv"
    )

    # Extract messages
    prompt_messages = prompt._template["messages"]

    system_prompt = next(

        (
            item["content"][0]["text"]
            for item in prompt_messages
            if item.get("role") == "system"
        ),

        None
    )

    if not system_prompt:
        raise ValueError(
            "Phoenix prompt missing or invalid"
        )

    # Format prompt
    try:

        final_prompt = system_prompt.format(
            text=text
        )

    except KeyError as e:

        raise ValueError(
            f"Missing variable in prompt: {e}"
        )

    return final_prompt


# Example usage
if __name__ == "__main__":

    sample_text = """
    Artificial Intelligence helps computers learn from data.
    """

    prompt = get_final_prompt(
        sample_text
    )

    print("\nFINAL PROMPT:\n")

    print(prompt)


